{
  "name": "aram-bridge",
  "version": "1.0.0",
  "description": "ARAM 내전 LCU 브릿지 — 롤 클라이언트 데이터를 Firebase로 전송",
  "main": "index.js",
  "bin": "index.js",
  "scripts": {
    "start": "node index.js",
    "build": "pkg . --targets node18-win-x64 --output dist/aram-bridge.exe"
  },
  "pkg": {
    "targets": ["node18-win-x64"],
    "outputPath": "dist"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "lcu-connector": "^1.1.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
